# ──────────────────────────────────────────────────────────────
# FounderLab AI — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it is listed in .gitignore.
# ──────────────────────────────────────────────────────────────

# Supabase (required — powers auth + cloud data sync). In Vercel, set both
# VITE_* values for Production, Preview, and Development: Vite embeds only
# VITE_* values in the browser build. Use the HTTPS project origin only (for
# example https://project-ref.supabase.co), never /auth/v1 or /rest/v1.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional server-side aliases. The API safely falls back to the two VITE_ values
# above, so do not duplicate them unless your deployment policy requires aliases.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# API security (required outside local development)
# Comma-separated exact browser origins. Include the custom production domain.
FOUNDERLAB_ALLOWED_ORIGINS=
# Optional exact production origin, if preferred over the list above.
FOUNDERLAB_PRODUCTION_ORIGIN=
# Optional safe Vercel Preview controls. Configure only host fragments you own.
# When both values are set, a Preview hostname must match both (recommended):
# a project prefix and its owning Vercel-team suffix. Never use *.vercel.app.
# Example: founderlab-ai01- + -fouderlab-ai-s-projects.vercel.app
FOUNDERLAB_VERCEL_PREVIEW_HOST_SUFFIXES=
FOUNDERLAB_VERCEL_PREVIEW_HOST_PREFIXES=

# Durable per-user rate limiter (required in Vercel Preview and Production; API
# fails closed without it). These are server-only Upstash REST credentials.
# Never use a VITE_ prefix or place either value in browser code.
# Use separate Upstash databases for Preview and Production to isolate limits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional per-scope overrides, all values are positive integers.
FOUNDERLAB_RATE_LIMIT_AI_LIMIT=30
FOUNDERLAB_RATE_LIMIT_AI_WINDOW_SECONDS=60
FOUNDERLAB_RATE_LIMIT_YOUTUBE_LIMIT=10
FOUNDERLAB_RATE_LIMIT_YOUTUBE_WINDOW_SECONDS=60
FOUNDERLAB_RATE_LIMIT_TTS_LIMIT=20
FOUNDERLAB_RATE_LIMIT_TTS_WINDOW_SECONDS=60

# Development only. Never set either in Vercel or production. Auth bypass and
# in-memory limiting each require their own explicit development-only flag.
FOUNDERLAB_DEV_AUTH_BYPASS=false
FOUNDERLAB_DEV_RATE_LIMIT_FALLBACK=false

# Optional AI providers — add one or more keys for the providers you want to
# use. FounderLab startup and authentication do not require any AI key. Keys
# are server-side only (Vercel serverless). Never VITE_ prefix these.

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Groq — ultra-fast inference (https://console.groq.com)
GROQ_API_KEY=

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# ElevenLabs — premium TTS voices (Brian male / custom female)
# Get key at https://elevenlabs.io — free tier: 10,000 chars/month
# Optional: if unavailable, the authenticated browser client falls back to Web Speech.
ELEVENLABS_API_KEY=

# Local Ollama needs no Vercel or FounderLab environment variable. FounderLab
# calls http://localhost:11434 directly from the user's browser and remembers
# only the selected local model on that device. A hosted FounderLab origin must
# be explicitly allowed in Ollama's OLLAMA_ORIGINS configuration; see
# docs/ollama-local.md. Do not use a VITE_ Ollama URL and do not expose Ollama
# outside localhost just for FounderLab.
