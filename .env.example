# ──────────────────────────────────────────────────────────────
# FounderLab AI — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it is listed in .gitignore.
# ──────────────────────────────────────────────────────────────

# Supabase (required — powers auth + cloud data sync)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI Providers — add the key for whichever provider you want to use.
# Keys are server-side only (Vercel serverless). Never VITE_ prefix these.

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Groq — ultra-fast inference (https://console.groq.com)
GROQ_API_KEY=

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Ollama — local models, no key needed (set URL in app Settings)
# No env variable required. Configure the URL in Settings → AI Provider.
